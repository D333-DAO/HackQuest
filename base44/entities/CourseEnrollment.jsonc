{
  "name": "CourseEnrollment",
  "type": "object",
  "properties": {
    "student_name": {
      "type": "string",
      "description": "Name of the enrolled student"
    },
    "course_title": {
      "type": "string",
      "description": "Title of the course enrolled in"
    },
    "enrollment_date": {
      "type": "string",
      "format": "date",
      "description": "Date of enrollment"
    },
    "student_email": {
      "type": "string",
      "description": "Student's email address if found in the alert"
    },
    "source_email_id": {
      "type": "string",
      "description": "Gmail message ID that triggered this enrollment"
    },
    "raw_snippet": {
      "type": "string",
      "description": "Short snippet from the source email for reference"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional notes or description for this enrollment"
    }
  },
  "required": [
    "student_name",
    "course_title"
  ],
  "rls": {
    "create": {
      "data.student_email": "{{user.email}}",
      "user_condition": {
        "$ne": null
      }
    },
    "read": {
      "$or": [
        {
          "data.student_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.student_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.student_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}