{
  "name": "EnrollmentSync",
  "type": "object",
  "properties": {
    "message_id": {
      "type": "string",
      "description": "Gmail message ID"
    },
    "subject": {
      "type": "string",
      "description": "Email subject line"
    },
    "from_email": {
      "type": "string",
      "description": "Sender email address"
    },
    "raw_from": {
      "type": "string",
      "description": "Raw From header value"
    },
    "received_date": {
      "type": "string",
      "description": "Date header from the email"
    },
    "path_id": {
      "type": "string",
      "description": "Matched learning path ID"
    },
    "path_title": {
      "type": "string",
      "description": "Matched learning path title"
    },
    "status": {
      "type": "string",
      "enum": [
        "synced",
        "pending",
        "error"
      ],
      "default": "synced"
    }
  },
  "required": [
    "message_id",
    "subject"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}