{
  "name": "CourseProgress",
  "type": "object",
  "properties": {
    "enrollment_id": {
      "type": "string",
      "description": "Foreign key to CourseEnrollment"
    },
    "module_title": {
      "type": "string",
      "description": "Title of the course module"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "completed"
      ],
      "default": "not_started",
      "description": "Progress status of the module"
    },
    "completion_date": {
      "type": "string",
      "format": "date",
      "description": "Date the module was completed"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional notes or description for this progress record"
    }
  },
  "required": [
    "enrollment_id",
    "module_title"
  ],
  "rls": {
    "create": null,
    "read": {
      "$or": [
        {
          "data.enrollment_id": {
            "$in": "{{base44.entities.CourseEnrollment.filter({'data.student_email':'{{user.email}}'},'id')}}"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.enrollment_id": {
            "$in": "{{base44.entities.CourseEnrollment.filter({'data.student_email':'{{user.email}}'},'id')}}"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.enrollment_id": {
            "$in": "{{base44.entities.CourseEnrollment.filter({'data.student_email':'{{user.email}}'},'id')}}"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}